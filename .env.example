API_HOST=127.0.0.1
API_PORT=8787
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
ANALYZER_STRONG_MODEL=claude-sonnet-5
ANALYZER_CHAPTER_MODEL=claude-sonnet-5
# Use deterministic for a fast, zero-model-call local demo; omit for full AI synthesis.
ANALYZER_MODE=deterministic
ANALYZER_VERSION=6
ANALYZER_STAGE1_MAX_TOKENS=12000
ANALYZER_STAGE2_MAX_TOKENS=8000
ANALYZER_STAGE3_MAX_TOKENS=10000
ANALYZER_MODEL_TIMEOUT_MS=45000
ANALYZER_STRONG_INPUT_USD_PER_MTOK=5
ANALYZER_STRONG_OUTPUT_USD_PER_MTOK=25
ANALYZER_CHAPTER_INPUT_USD_PER_MTOK=2
ANALYZER_CHAPTER_OUTPUT_USD_PER_MTOK=10
ANALYZER_CONCURRENCY=5
ANALYZER_MAX_FILES=300
ANALYZER_MAX_CONTEXT_FILES=10
# Approximately 20k tokens at the default four-characters-per-token budget.
ANALYZER_MAX_CONTEXT_CHARACTERS=80000
STORY_WORKSPACE_ROOT=/tmp/review-story/workspaces
STORY_CACHE_ROOT=./.review-story/cache

# Server-only secrets. Never expose these through VITE_* variables.
OPENAI_API_KEY=
GITHUB_PAT=
# Use this to protect the hosted harness before adding full GitHub OAuth.
HARNESS_ACCESS_TOKEN=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# These Vite variables are read by the extension at build time.
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_DEMO_OWNER=itayfry
VITE_DEMO_REPO=king-of-tokens
# Update once the ~80-file demo PR is opened (tracked in issue #3).
VITE_DEMO_PR=1
VITE_DEMO_HEAD_SHA=
VITE_HARNESS_ACCESS_TOKEN=
