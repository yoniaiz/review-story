API_HOST=127.0.0.1
API_PORT=8787
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
ANALYZER_STRONG_MODEL=claude-sonnet-5
ANALYZER_CHAPTER_MODEL=claude-sonnet-5
# full = real model synthesis (production). deterministic is a dev/test-only
# zero-model-call mode; never deploy with it set.
ANALYZER_MODE=full
ANALYZER_VERSION=7
ANALYZER_STAGE1_MAX_TOKENS=12000
ANALYZER_STAGE2_MAX_TOKENS=8000
ANALYZER_STAGE3_MAX_TOKENS=10000
ANALYZER_MODEL_TIMEOUT_MS=45000
ANALYZER_STRONG_INPUT_USD_PER_MTOK=5
ANALYZER_STRONG_OUTPUT_USD_PER_MTOK=25
ANALYZER_CHAPTER_INPUT_USD_PER_MTOK=2
ANALYZER_CHAPTER_OUTPUT_USD_PER_MTOK=10
ANALYZER_CONCURRENCY=5
ANALYZER_MAX_FILES=300
ANALYZER_MAX_CONTEXT_FILES=10
# Approximately 20k tokens at the default four-characters-per-token budget.
ANALYZER_MAX_CONTEXT_CHARACTERS=80000
STORY_WORKSPACE_ROOT=/tmp/review-story/workspaces
STORY_CACHE_ROOT=./.review-story/cache
# Keep local demos independent of hosted schema migrations. Remove this or set
# it to supabase after applying supabase/migrations/20260721_review_harness.sql.
REVIEW_SESSION_STORE=memory

# Server-only secrets. Never expose these through VITE_* variables.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-terra
GITHUB_PAT=

# GitHub App ("Sign in with GitHub"). Register an App with Pull requests R/W,
# Contents R, Metadata R, expiring user tokens, and callback
# <API_PUBLIC_BASE_URL>/auth/github/callback.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# 32 bytes base64 (openssl rand -base64 32); encrypts stored GitHub tokens.
TOKEN_ENCRYPTION_KEY=
# Comma-separated Chrome extension IDs allowed as sign-in redirect targets.
# Dev builds are pinned to appnfmeigeoabcmbkacboonafmmiakep by the manifest
# "key" in wxt.config.ts; a Chrome Web Store release would add its own ID.
EXTENSION_IDS=appnfmeigeoabcmbkacboonafmmiakep
# Public URL of the hosted API, used to build the OAuth callback URL.
API_PUBLIC_BASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# These Vite variables are read by the extension at build time. The demo
# identity is used only by the standalone `?preview=pr` surface; it does not
# restrict which live GitHub pull requests the extension can analyze.
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_DEMO_OWNER=itayfry
VITE_DEMO_REPO=king-of-tokens
# Update once the ~80-file demo PR is opened (tracked in issue #3).
VITE_DEMO_PR=1
VITE_DEMO_HEAD_SHA=
